{
  "name": "@trace/server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:firebase-admin --external:firebase-functions --external:expo-server-sdk --external:stripe --external:@anthropic-ai/sdk --external:cors --external:express",
    "dev": "tsx watch src/dev.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@trace/shared": "file:../shared",
    "cors": "^2.8.5",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "dotenv": "^16.5.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
