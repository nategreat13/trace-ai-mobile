STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
FIREBASE_PROJECT_ID=...
FIREBASE_CLIENT_EMAIL=...
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
NEXT_PUBLIC_URL=http://localhost:3000

# Analytics dashboard (/analytics)
ANALYTICS_PASSWORD=...
REVENUECAT_REST_KEY=sk_...
# Optional: override auto-discovered RC project ID
# REVENUECAT_PROJECT_ID=proj_...

# Shared admin token: lets the web's "Send test push", "Send broadcast",
# and "Seed templates" actions reach the Cloud Function's /admin/* routes.
# Same value as ADMIN_API_TOKEN in Firebase Secret Manager — fetch with:
#   firebase functions:secrets:access ADMIN_API_TOKEN --project trace-ai-b9cba
ADMIN_API_TOKEN=...

# Optional. Defaults to the deployed Cloud Function URL. Set this to
# http://localhost:3001 if you're running `yarn dev1` and want admin
# actions to hit your local server instead of production.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
