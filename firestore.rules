rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──── User Profiles ────
    match /userProfiles/{docId} {

      // Users can read their own profile
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      // Users can create a profile for themselves (subscription defaults to "free")
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.subscriptionStatus == "free";

      // Users can update their own profile but NOT subscription/Stripe fields
      // (those are written by the server via Admin SDK which bypasses rules)
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
                    && request.resource.data.trialEndDate == resource.data.trialEndDate
                    && unchangedStripeFields();

      // Users can delete their own profile (account deletion)
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      function unchangedStripeFields() {
        // If a Stripe field doesn't exist yet on the doc, it also shouldn't appear in the update.
        // Using the "field exists ? must match : must not be added" pattern.
        let after = request.resource.data;
        let before = resource.data;
        return (!("stripeCustomerId" in after) || after.stripeCustomerId == before.stripeCustomerId)
            && (!("stripeSubscriptionId" in after) || after.stripeSubscriptionId == before.stripeSubscriptionId)
            && (!("stripeSubscriptionStatus" in after) || after.stripeSubscriptionStatus == before.stripeSubscriptionStatus)
            && (!("stripePriceId" in after) || after.stripePriceId == before.stripePriceId)
            && (!("stripeCurrentPeriodEnd" in after) || after.stripeCurrentPeriodEnd == before.stripeCurrentPeriodEnd);
      }
    }

    // ──── Swipe Actions ────
    match /swipeActions/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Swipes are immutable — no updates allowed
    }

    // ──── Saved Flight Deals ────
    match /flightDeals/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Saved deals are immutable — no updates allowed
    }

    // ──── Deal Alerts ────
    match /dealAlerts/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Users can update their own alerts (e.g. status change to "matched")
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ──── Events (analytics) ────
    // Append-only event log written by the mobile app (client SDK) and
    // by the server (Admin SDK, which bypasses these rules).
    //
    // Clients can only create events tagged with their own userId — or
    // the literal string "guest" before sign-in. This prevents a logged-
    // in user from spoofing events as another user, and prevents anyone
    // from spoofing the server's `source: revenuecat_webhook` events.
    //
    // No client reads — events contain other users' activity and the
    // dashboard reads them via Admin SDK on the server.
    match /events/{docId} {
      allow create: if isOwnEventCreate();
      allow read, update, delete: if false;

      function isOwnEventCreate() {
        let d = request.resource.data;
        // Clients must not stamp `source` — that field is reserved for
        // server-emitted events (e.g. "revenuecat_webhook").
        return !("source" in d)
          && d.keys().hasAll(["name", "userId", "timestamp"])
          && (
            // Authenticated user logging their own event
            (request.auth != null && d.userId == request.auth.uid)
            // Or unauthenticated user logging a guest event
            || (request.auth == null && d.userId == "guest")
          );
      }
    }

    // ──── Analytics Exclusions ────
    // Admin-only list of internal/test accounts to keep out of dashboard
    // stats. Reads and writes happen exclusively from the dashboard server
    // via the Firebase Admin SDK (which bypasses these rules), so all
    // client traffic is denied.
    match /analyticsExclusions/{docId} {
      allow read, write: if false;
    }

    // ──── Admin Audit Log ────
    // Append-only log of admin actions. Same access pattern as
    // analyticsExclusions: server-only via Admin SDK; clients denied.
    match /adminAuditLog/{docId} {
      allow read, write: if false;
    }

    // ──── Promo Codes ────
    // Generated by admin, validated and applied by /redeem-promo on the
    // server (which uses the Admin SDK). Clients must never read or write
    // the codes directly — that would let users enumerate all codes.
    match /promoCodes/{docId} {
      allow read, write: if false;
    }

    // ──── Promo Redemptions ────
    // Server-written audit trail of who redeemed what. No client access.
    match /promoRedemptions/{docId} {
      allow read, write: if false;
    }

    // ──── Notification Templates ────
    // Admin-edited copy for triggered notifications. Reads/writes happen
    // exclusively from the dashboard server (Vercel) and the Cloud
    // Function via the Admin SDK — clients should never need them.
    match /notificationTemplates/{docId} {
      allow read, write: if false;
    }

    // ──── Notification Log ────
    // Append-only history of every push notification sent. Server-only.
    match /notificationLog/{docId} {
      allow read, write: if false;
    }

    // ──── Deny everything else ────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
