rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║                        PROD COLLECTIONS                          ║
    // ║                                                                  ║
    // ║  These are the real-user collections. Mirror blocks for staging_*║
    // ║  appear further down. Keep the two sets in sync.                 ║
    // ╚══════════════════════════════════════════════════════════════════╝

    // ──── User Profiles ────
    match /userProfiles/{docId} {

      // Users can read their own profile
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      // Users can create a profile for themselves (subscription defaults to "free")
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.subscriptionStatus == "free";

      // Users can update their own profile but NOT subscription/Stripe fields
      // (those are written by the server via Admin SDK which bypasses rules)
      // Note: subscriptionStatus/trialEndDate/inTrial use get(field, null)
      // instead of plain dot access — direct access to a field absent from
      // the document errors out rule evaluation (Firestore treats an
      // erroring rule as deny), and inTrial in particular is never set by
      // client-side profile creation, so plain dot access here denied every
      // client-side profile update for any account that had never started
      // a trial. Found 2026-07-16.
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.get('subscriptionStatus', null) == resource.data.get('subscriptionStatus', null)
                    && request.resource.data.get('trialEndDate', null) == resource.data.get('trialEndDate', null)
                    && request.resource.data.get('inTrial', null) == resource.data.get('inTrial', null)
                    && unchangedStripeFields();

      // Users can delete their own profile (account deletion)
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      function unchangedStripeFields() {
        // If a Stripe field doesn't exist yet on the doc, it also shouldn't appear in the update.
        // Using the "field exists ? must match : must not be added" pattern.
        let after = request.resource.data;
        let before = resource.data;
        return (!("stripeCustomerId" in after) || after.stripeCustomerId == before.stripeCustomerId)
            && (!("stripeSubscriptionId" in after) || after.stripeSubscriptionId == before.stripeSubscriptionId)
            && (!("stripeSubscriptionStatus" in after) || after.stripeSubscriptionStatus == before.stripeSubscriptionStatus)
            && (!("stripePriceId" in after) || after.stripePriceId == before.stripePriceId)
            && (!("stripeCurrentPeriodEnd" in after) || after.stripeCurrentPeriodEnd == before.stripeCurrentPeriodEnd);
      }
    }

    // ──── Swipe Actions ────
    match /swipeActions/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Swipes are immutable — no updates allowed
    }

    // ──── Saved Flight Deals ────
    match /flightDeals/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Saved deals are immutable — no updates allowed
    }

    // ──── Deal Alerts ────
    match /dealAlerts/{docId} {

      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Users can update their own alerts (e.g. status change to "matched")
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ──── Events (analytics) ────
    // Append-only event log written by the mobile app (client SDK) and
    // by the server (Admin SDK, which bypasses these rules).
    //
    // Clients can only create events tagged with their own userId — or
    // the literal string "guest" before sign-in. This prevents a logged-
    // in user from spoofing events as another user, and prevents anyone
    // from spoofing the server's `source: revenuecat_webhook` events.
    //
    // No client reads — events contain other users' activity and the
    // dashboard reads them via Admin SDK on the server.
    match /events/{docId} {
      allow create: if isOwnEventCreate();
      allow read, update, delete: if false;

      function isOwnEventCreate() {
        let d = request.resource.data;
        // Clients must not stamp `source` — that field is reserved for
        // server-emitted events (e.g. "revenuecat_webhook").
        return !("source" in d)
          && d.keys().hasAll(["name", "userId", "timestamp"])
          && (
            // Authenticated user logging their own event
            (request.auth != null && d.userId == request.auth.uid)
            // Or unauthenticated user logging a guest event
            || (request.auth == null && d.userId == "guest")
          );
      }
    }

    // ──── Analytics Exclusions ────
    // Admin-only list of internal/test accounts to keep out of dashboard
    // stats. Reads and writes happen exclusively from the dashboard server
    // via the Firebase Admin SDK (which bypasses these rules), so all
    // client traffic is denied.
    match /analyticsExclusions/{docId} {
      allow read, write: if false;
    }

    // ──── Admin Audit Log ────
    // Append-only log of admin actions. Same access pattern as
    // analyticsExclusions: server-only via Admin SDK; clients denied.
    match /adminAuditLog/{docId} {
      allow read, write: if false;
    }

    // ──── Webhook event dedupe ────
    // Server-only. The RevenueCat webhook writes one doc per processed event
    // id (idempotency lock). Clients must never touch it.
    match /webhookEvents/{docId} {
      allow read, write: if false;
    }

    // ──── Promo Codes ────
    // Generated by admin, validated and applied by /redeem-promo on the
    // server (which uses the Admin SDK). Clients must never read or write
    // the codes directly — that would let users enumerate all codes.
    match /promoCodes/{docId} {
      allow read, write: if false;
    }

    // ──── Promo Redemptions ────
    // Server-written audit trail of who redeemed what. No client access.
    match /promoRedemptions/{docId} {
      allow read, write: if false;
    }

    // ──── Notification Templates ────
    // Admin-edited copy for triggered notifications. Reads/writes happen
    // exclusively from the dashboard server (Vercel) and the Cloud
    // Function via the Admin SDK — clients should never need them.
    match /notificationTemplates/{docId} {
      allow read, write: if false;
    }

    // ──── Notification Log ────
    // Append-only history of every push notification sent. Server-only.
    match /notificationLog/{docId} {
      allow read, write: if false;
    }

    // ──── Hot Deal Cache ────
    // Per-user dedup state for the hot_deal_alert push (keyed by userId).
    // Written by the daily notification cron via Admin SDK; clients never
    // touch it directly. Same access pattern as notificationLog.
    match /hotDealCache/{docId} {
      allow read, write: if false;
    }

    // Written by the deal-of-the-day cron via Admin SDK (per-user dedup of
    // sent destinations); clients never touch it directly.
    match /dotdCache/{docId} {
      allow read, write: if false;
    }

    // Sandbox/staging email whitelist — the only addresses allowed to receive
    // Klaviyo email while env=staging. Managed in the admin portal via Admin
    // SDK; clients never touch it.
    match /sandboxEmailWhitelist/{docId} {
      allow read, write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║                      STAGING COLLECTIONS                         ║
    // ║                                                                  ║
    // ║  Mirror of the prod blocks above, prefixed with `staging_`. The  ║
    // ║  logic is identical — only the collection name differs. If you  ║
    // ║  change a prod rule, change the corresponding staging rule.     ║
    // ║                                                                  ║
    // ║  Note: this still uses real Firebase Auth (same user pool as    ║
    // ║  prod — decision 1), so the same uid checks apply. A staging    ║
    // ║  user is just a real Firebase Auth user whose userProfile doc   ║
    // ║  lives under the prefixed collection.                            ║
    // ╚══════════════════════════════════════════════════════════════════╝

    match /staging_userProfiles/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.subscriptionStatus == "free";

      // See matching note in the prod userProfiles block above.
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.get('subscriptionStatus', null) == resource.data.get('subscriptionStatus', null)
                    && request.resource.data.get('trialEndDate', null) == resource.data.get('trialEndDate', null)
                    && request.resource.data.get('inTrial', null) == resource.data.get('inTrial', null)
                    && stagingUnchangedStripeFields();

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      function stagingUnchangedStripeFields() {
        let after = request.resource.data;
        let before = resource.data;
        return (!("stripeCustomerId" in after) || after.stripeCustomerId == before.stripeCustomerId)
            && (!("stripeSubscriptionId" in after) || after.stripeSubscriptionId == before.stripeSubscriptionId)
            && (!("stripeSubscriptionStatus" in after) || after.stripeSubscriptionStatus == before.stripeSubscriptionStatus)
            && (!("stripePriceId" in after) || after.stripePriceId == before.stripePriceId)
            && (!("stripeCurrentPeriodEnd" in after) || after.stripeCurrentPeriodEnd == before.stripeCurrentPeriodEnd);
      }
    }

    match /staging_swipeActions/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    match /staging_flightDeals/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    match /staging_dealAlerts/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    match /staging_events/{docId} {
      allow create: if isOwnStagingEventCreate();
      allow read, update, delete: if false;

      function isOwnStagingEventCreate() {
        let d = request.resource.data;
        return !("source" in d)
          && d.keys().hasAll(["name", "userId", "timestamp"])
          && (
            (request.auth != null && d.userId == request.auth.uid)
            || (request.auth == null && d.userId == "guest")
          );
      }
    }

    // Server-only staging collections — deny all client access. Match
    // the prod policy block-for-block.
    match /staging_analyticsExclusions/{docId} { allow read, write: if false; }
    match /staging_adminAuditLog/{docId}       { allow read, write: if false; }
    match /staging_webhookEvents/{docId}       { allow read, write: if false; }
    match /staging_promoCodes/{docId}          { allow read, write: if false; }
    match /staging_promoRedemptions/{docId}    { allow read, write: if false; }
    match /staging_notificationTemplates/{docId} { allow read, write: if false; }
    match /staging_notificationLog/{docId}     { allow read, write: if false; }
    match /staging_hotDealCache/{docId}        { allow read, write: if false; }
    match /staging_dotdCache/{docId}           { allow read, write: if false; }
    match /staging_sandboxEmailWhitelist/{docId} { allow read, write: if false; }

    // ──── Deny everything else ────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
