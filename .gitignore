# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Generated at build time by eas-build-pre-install.sh / `yarn prestart`.
# Holds the git SHA + build timestamp surfaced on the diagnostics screen.
projects/app/build-info.json

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Encrypted secret bundles for transferring env files to teammates.
# Should never end up in git history even password-protected.
envs.zip
*.env.zip

# Generated documents (test plans, exports). Always regenerable.
*.pdf

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
projects/app/ios/
projects/app/android/

# monorepo build artifacts
projects/shared/dist/
projects/server/dist/
projects/server/shared/

# Vercel CLI link state — machine-local, contains projectId/orgId.
# Vercel docs explicitly say not to commit this.
.vercel
