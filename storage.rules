rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ──── Profile photos ────
    // Each user has at most one profile photo at /profilePhotos/{uid}.
    // Read is restricted to the owner — for *finding* the file via the
    // Storage SDK. Note that once the download URL is in
    // userProfile.profilePictureUrl, that URL has its own embedded
    // token and is fetchable without these rules; that's how Firebase
    // download URLs work and is the same model used by every Firebase
    // app that displays user-uploaded images.
    match /profilePhotos/{userId} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // 5 MB cap
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ──── Deny everything else ────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
